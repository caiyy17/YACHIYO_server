{
    "pipeline": [
        {
            "node_id": 1,
            "function": "call_openai_llm",
            "config": {
                "input_vars": [
                    {
                        "source": "text",
                        "target": "prompt"
                    }
                ],
                "pass_vars": [
                    {
                        "source": "text",
                        "target": "prompt"
                    }
                ],
                "output_vars": [
                    {
                        "source": "text",
                        "target": "2_text"
                    },
                    {
                        "source": "action",
                        "target": "2_action"
                    },
                    {
                        "source": "expression",
                        "target": "2_expression"
                    }
                ],
                "emit_signals": [
                    {
                        "source": "SoS",
                        "target": "SoS"
                    },
                    {
                        "source": "EoS",
                        "target": "EoS"
                    }
                ],
                "next_nodes": [2],
                "history_mode": "tavern",
                "lorebooks": [
                    {
                        "name": "unity_chan",
                        "offset": 0
                    }
                ],
                "similarity_threshold": 0.8,
                "reset_history": true,
                "history_length": 10,
                "model": "gemma",
                "punctuations": "、：，。？！:,.?!\n\t",
                "sentence_length_threshold": 10,
                "extra_info": {
                    "action": {
                        "start_mark": "[",
                        "end_mark": "]"
                    },
                    "expression": {
                        "start_mark": "(",
                        "end_mark": ")"
                    }
                }
            }
        },
        {
            "node_id": 2,
            "function": "call_data_query_link",
            "config": {
                "input_vars": [
                    {
                        "source": "2_expression",
                        "target": "prompt"
                    }
                ],
                "pass_vars": [
                    {
                        "source": "2_text",
                        "target": "3_text"
                    },
                    {
                        "source": "2_action",
                        "target": "3_action"
                    },
                    {
                        "source": "2_expression",
                        "target": "3_expression_hint"
                    }
                ],
                "output_vars": [
                    {
                        "source": "result",
                        "target": "3_expression"
                    }
                ],
                "pass_signals": [
                    {
                        "source": "EoS",
                        "target": "EoS"
                    },
                    {
                        "source": "SoS",
                        "target": "SoS"
                    }
                ],
                "next_nodes": [3],
                "dataset": "unity_chan_expression_list",
                "type": "BGE",
                "k": 5,
                "score_threshold": 0.6
            }
        },
        {
            "node_id": 3,
            "function": "call_joint_stream",
            "config": {
                "input_vars": [
                    {
                        "source": "3_text",
                        "target": "text"
                    },
                    {
                        "source": "3_action",
                        "target": "prompt"
                    }
                ],
                "pass_vars": [
                    {
                        "source": "3_text",
                        "target": "text"
                    },
                    {
                        "source": "3_action",
                        "target": "action_hint"
                    },
                    {
                        "source": "3_expression",
                        "target": "expression"
                    },
                    {
                        "source": "3_expression_hint",
                        "target": "expression_hint"
                    }
                ],
                "output_vars": [
                    {
                        "source": "audio",
                        "target": "audio_data"
                    },
                    {
                        "source": "motion",
                        "target": "action"
                    }
                ],
                "catch_signals": [
                    {
                        "source": "SoS",
                        "target": "SoS"
                    }
                ],
                "pass_signals": [
                    {
                        "source": "EoS",
                        "target": "EoS"
                    },
                    {
                        "source": "SoS",
                        "target": "SoS"
                    }
                ],
                "emit_signals": [
                    {
                        "source": "SoS",
                        "target": "js_SoS"
                    },
                    {
                        "source": "EoS",
                        "target": "js_EoS"
                    }
                ],
                "streams": [
                    {
                        "caller": "openai_tts",
                        "input": [
                            {
                                "source": "text",
                                "target": "prompt"
                            }
                        ],
                        "output": [
                            {
                                "source": "audio",
                                "target": "audio"
                            }
                        ],
                        "config": {
                            "model": "qwen_tts",
                            "voice": "test_cn",
                            "stream_chunk_ms": 300
                        }
                    },
                    {
                        "caller": "motion_generation",
                        "input": [
                            {
                                "source": "prompt",
                                "target": "prompt"
                            }
                        ],
                        "output": [
                            {
                                "source": "motion",
                                "target": "motion"
                            }
                        ],
                        "config": {
                            "model": "hy_motion",
                            "duration": 5.0,
                            "continuous": true,
                            "history_size": 5,
                            "stream_frames": 9
                        }
                    }
                ],
                "next_nodes": [-1]
            }
        }
    ]
}
