{
    "webrtc": {
        "audio_fps": 50,
        "video_fps": 30,
        "data_fps": 20,
        "startup_buffer": 2,
        "dc_offset_ms": 0
    },
    "pipeline": [
        {
            "node_id": 1,
            "function": "frame_collector",
            "config": {
                "input_vars": [
                    {
                        "source": "audio",
                        "target": "audio"
                    },
                    {
                        "source": "video",
                        "target": "video"
                    },
                    {
                        "source": "data",
                        "target": "data"
                    }
                ],
                "pass_vars": [],
                "output_vars": [
                    {
                        "source": "audio_data",
                        "target": "1_audio_data"
                    },
                    {
                        "source": "video_data",
                        "target": "1_video_data"
                    },
                    {
                        "source": "payload",
                        "target": "1_payload"
                    }
                ],
                "pass_signals": [
                    {
                        "source": "connection_start",
                        "target": "connection_start"
                    }
                ],
                "next_nodes": [
                    2
                ]
            }
        },
        {
            "node_id": 2,
            "function": "frame_splitter",
            "config": {
                "input_vars": [
                    {
                        "source": "1_audio_data",
                        "target": "audio_data"
                    },
                    {
                        "source": "1_video_data",
                        "target": "video_data"
                    },
                    {
                        "source": "1_payload",
                        "target": "payload"
                    }
                ],
                "pass_vars": [],
                "output_vars": [
                    {
                        "source": "audio",
                        "target": "audio"
                    },
                    {
                        "source": "video",
                        "target": "video"
                    },
                    {
                        "source": "data",
                        "target": "data"
                    }
                ],
                "catch_signals": [
                    {
                        "source": "connection_start",
                        "target": "connection_start"
                    }
                ],
                "pass_signals": [],
                "next_nodes": [
                    -1
                ]
            }
        }
    ]
}
